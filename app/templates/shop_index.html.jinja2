{% if not request.headers.hx_request %}
    {% extends "layout.html.jinja2" %}
{% endif %}
{% block title %}Shops — items | {% endblock title %}
{% block content %}
    <h1>Shops</h1>
    <section>
        <select class="shopSelect"
                name="shopSelect"
                aria-label="Select shop"
                required
                hx-get="{{ url_for('items.get_shop_index') }}"
                hx-target="#shopSheet"
                hx-indicator="#shopSheet">
            <option value="default" selected disabled>Select a shop</option>
            {% for shop in shops %}
                <option value="{{ shop.nid }}">{{ shop.name }}</option>
            {% endfor %}
        </select>
    </section>
    <section id="shopSheet">
        <div aria-busy="true" class="htmx-indicator"></div>
        <div hx-get="{{ url_for('items.get_shop_index',shopSelect=(shops|first).nid) }}"
             hx-trigger="load"
             hx-target="#shopSheet"></div>
    </section>
{% endblock content %}
